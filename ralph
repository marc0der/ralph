#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"
CONFIG_DIR="${RALPH_CONFIG_DIR:-$HOME/.config/ralph}"

# Default caps prevent runaway loops
PLAN_DEFAULT_CAP=3
BUILD_DEFAULT_CAP=50

ARTIFACTS=(IMPLEMENTATION_PLAN.md PROGRESS.md PROMPT_plan.md PROMPT_build.md)
ARCHIVE_DIR=".ralph"

usage() {
    cat <<'EOF'
ralph — autonomous Claude Code loop runner

Usage:
  ralph sandbox [--rebuild]
  ralph sandbox clean
  ralph <plan|build> [options]
  ralph init
  ralph clean
  ralph archive
  ralph version

Modes:
  sandbox        Enter a devcontainer shell for the current project
  sandbox clean  Remove the devcontainer for the current project
  plan           Analyse specs and source, create/update IMPLEMENTATION_PLAN.md
  build          Pick the next item, implement, test, commit, push
  init           Initialise workspace (PROGRESS.md, IMPLEMENTATION_PLAN.md, specs/)
  clean          Delete IMPLEMENTATION_PLAN.md and PROGRESS.md
  archive        Move IMPLEMENTATION_PLAN.md and PROGRESS.md to .ralph/<timestamp>/

Sandbox options:
      --rebuild        Rebuild the container image from scratch

Init options:
  -p, --prompts      Also copy prompt templates for local customisation

Options:
  -n, --iterations N   Max iterations (plan default: 3, build default: 50)
  -g, --goal TEXT      Goal to inject into the prompt template
  -m, --model MODEL    Claude model to use (default: opus)
      --skip-push      Don't push after each iteration
      --dry-run        Print what would be executed without running
  -h, --help           Show this help message

Examples:
  ralph plan
  ralph plan -n 2
  ralph plan -g "Migrate to hexagonal architecture"
  ralph build -n 10 -m sonnet
  ralph build --iterations 5 --goal "Add PATCH endpoint"
  ralph sandbox
  ralph sandbox --rebuild
  ralph sandbox clean
  ralph archive
EOF
    exit 0
}

cmd_version() {
    echo "ralph $VERSION"
    exit 0
}

cmd_clean() {
    local found=false
    for file in "${ARTIFACTS[@]}"; do
        if [[ -f "$file" ]]; then
            rm "$file"
            echo "Deleted: $file"
            found=true
        fi
    done
    $found || echo "Nothing to clean."
}

cmd_archive() {
    local found=false
    for file in "${ARTIFACTS[@]}"; do
        if [[ -f "$file" ]]; then
            found=true
            break
        fi
    done

    if ! $found; then
        echo "Nothing to archive."
        return
    fi

    local timestamp
    timestamp=$(date +%Y%m%d-%H%M%S)
    local dest="$ARCHIVE_DIR/$timestamp"
    mkdir -p "$dest"

    for file in "${ARTIFACTS[@]}"; do
        if [[ -f "$file" ]]; then
            mv "$file" "$dest/"
            echo "Archived: $file -> $dest/$file"
        fi
    done
}

cmd_init() {
    local with_prompts=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p|--prompts) with_prompts=true; shift ;;
            *) echo "Error: unknown init option '$1'"; exit 1 ;;
        esac
    done

    local templates_dir="$CONFIG_DIR/templates"

    # Workspace artifacts
    if [[ -f "$templates_dir/PROGRESS.md" ]]; then
        scaffold "PROGRESS.md" "$templates_dir/PROGRESS.md"
    else
        echo "Warning: PROGRESS.md template not found at $templates_dir"
    fi

    if [[ -f "IMPLEMENTATION_PLAN.md" ]]; then
        echo "Skipped: IMPLEMENTATION_PLAN.md already exists"
    else
        touch "IMPLEMENTATION_PLAN.md"
        echo "Created: IMPLEMENTATION_PLAN.md"
    fi

    if [[ -d "specs" ]]; then
        echo "Skipped: specs/ already exists"
    else
        mkdir -p "specs"
        echo "Created: specs/"
    fi

    # Add ralph artifacts to .gitignore
    if [[ -f ".gitignore" ]]; then
        # Ensure file ends with a newline before appending
        [[ -s .gitignore && $(tail -c1 .gitignore) != "" ]] && echo >> .gitignore
        local ignore_entries=("IMPLEMENTATION_PLAN.md" "PROGRESS.md" ".ralph/" "PROMPT_plan.md" "PROMPT_build.md")
        for entry in "${ignore_entries[@]}"; do
            if ! grep -qxF "$entry" .gitignore; then
                echo "$entry" >> .gitignore
                echo "Added to .gitignore: $entry"
            fi
        done
    fi

    # Optional: copy prompt templates for local customisation
    if $with_prompts; then
        local prompts_dir="$CONFIG_DIR/prompts"
        if [[ ! -d "$prompts_dir" ]]; then
            echo "Error: ralph prompts not found at $prompts_dir"
            echo "Run the installer first: ./install.sh"
            exit 1
        fi
        for file in plan.md build.md; do
            scaffold "PROMPT_${file}" "$prompts_dir/$file"
        done
    fi
}

scaffold() {
    local target="$1"
    local source="$2"
    if [[ -f "$target" ]]; then
        echo "Skipped: $target already exists"
    else
        cp "$source" "$target"
        echo "Created: $target"
    fi
}

cmd_sandbox() {
    local rebuild=false

    case "${1:-}" in
        clean)     sandbox_clean; return ;;
        --rebuild) rebuild=true ;;
        "")        ;;
        *)         echo "Error: unknown sandbox option '$1'" >&2; exit 1 ;;
    esac

    if ! command -v devcontainer >/dev/null 2>&1; then
        echo "Error: 'devcontainer' CLI not found in PATH." >&2
        echo "Install it with: npm install -g @devcontainers/cli" >&2
        exit 1
    fi

    if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echo "Error: not inside a git repository." >&2
        exit 1
    fi

    local config="$CONFIG_DIR/container/devcontainer.json"
    if [[ ! -f "$config" ]]; then
        echo "Error: devcontainer config not found at $config" >&2
        echo "Run the installer first: ./install.sh" >&2
        exit 1
    fi

    mkdir -p "$HOME/.claude"

    # Runtime mounts (conditional on host file existence)
    local mounts=()
    local ralph_bin
    ralph_bin="$(command -v ralph)"
    mounts+=("type=bind,source=$ralph_bin,target=/usr/local/bin/ralph")
    mounts+=("type=bind,source=$CONFIG_DIR,target=/home/node/.config/ralph")

    if [[ -d "$HOME/.ssh" ]]; then
        mounts+=("type=bind,source=$HOME/.ssh,target=/home/node/.ssh")
    fi
    if [[ -d "$HOME/.config/gh" ]]; then
        mounts+=("type=bind,source=$HOME/.config/gh,target=/home/node/.config/gh")
    fi

    local ssh_env=()
    if [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
        mounts+=("type=bind,source=$SSH_AUTH_SOCK,target=/tmp/ssh-agent.sock")
        ssh_env=("--remote-env" "SSH_AUTH_SOCK=/tmp/ssh-agent.sock")
    fi

    # Shell history volume (deterministic per workspace)
    local workspace_hash
    workspace_hash=$(echo -n "$PWD" | md5sum | cut -c1-12)
    mounts+=("type=volume,source=ralph-history-${workspace_hash},target=/commandhistory")

    local mount_flags=()
    for mount in "${mounts[@]}"; do
        mount_flags+=("--mount" "$mount")
    done

    # Start or reuse container
    local up_args=(
        "--workspace-folder" "$PWD"
        "--config" "$config"
        "${mount_flags[@]}"
        "${ssh_env[@]}"
    )
    if $rebuild; then
        up_args+=("--remove-existing-container" "--build-no-cache")
    fi

    echo "Starting sandbox..."
    devcontainer up "${up_args[@]}"

    # Drop into shell
    devcontainer exec \
        --workspace-folder "$PWD" \
        --config "$config" \
        "${ssh_env[@]}" \
        zsh
}

sandbox_clean() {
    if ! command -v docker >/dev/null 2>&1; then
        echo "Error: 'docker' not found in PATH." >&2
        exit 1
    fi

    local container_id
    container_id=$(docker ps -a --filter "label=devcontainer.local_folder=$PWD" --format '{{.ID}}')

    if [[ -z "$container_id" ]]; then
        echo "No sandbox container found for $PWD"
        return
    fi

    docker rm -f "$container_id" >/dev/null
    echo "Removed sandbox container for $PWD"
}

# Resolve which prompt file to use.
# Priority: project-local PROMPT_<mode>.md > installed default
resolve_prompt() {
    local mode="$1"
    local local_file="PROMPT_${mode}.md"
    local default_file="$CONFIG_DIR/prompts/${mode}.md"

    if [[ -f "$local_file" ]]; then
        echo "$local_file"
    elif [[ -f "$default_file" ]]; then
        echo "$default_file"
    else
        echo "Error: no prompt found for mode '$mode'" >&2
        echo "Looked for: $local_file, $default_file" >&2
        echo "Run 'ralph init' to scaffold local prompts, or reinstall with ./install.sh" >&2
        exit 1
    fi
}

cmd_loop() {
    local mode="$1"
    shift

    # Parse flags
    local max_iterations=""
    local goal=""
    local model="opus"
    local skip_push=false
    local dry_run=false

    ARGS=$(getopt -o n:g:m:h --long iterations:,goal:,model:,skip-push,dry-run,help -n 'ralph' -- "$@")
    eval set -- "$ARGS"

    while true; do
        case "$1" in
            -n|--iterations) max_iterations="$2"; shift 2 ;;
            -g|--goal)       goal="$2";           shift 2 ;;
            -m|--model)      model="$2";          shift 2 ;;
            --skip-push)     skip_push=true;      shift ;;
            --dry-run)       dry_run=true;        shift ;;
            -h|--help)       usage ;;
            --)              shift; break ;;
        esac
    done

    # Apply default iteration cap based on mode
    if [[ -z "$max_iterations" ]]; then
        case "$mode" in
            plan)  max_iterations=$PLAN_DEFAULT_CAP  ;;
            build) max_iterations=$BUILD_DEFAULT_CAP ;;
        esac
    fi

    # Validate iterations is a positive integer
    if [[ ! "$max_iterations" =~ ^[1-9][0-9]*$ ]]; then
        echo "Error: iterations must be a positive integer, got '$max_iterations'" >&2
        exit 1
    fi

    # Verify claude CLI is available (not needed for dry-run)
    if ! $dry_run && ! command -v claude >/dev/null 2>&1; then
        echo "Error: 'claude' CLI not found in PATH." >&2
        echo "Install it from https://docs.anthropic.com/en/docs/claude-code" >&2
        exit 1
    fi

    # Verify git is available and we're inside a repo
    if ! command -v git >/dev/null 2>&1; then
        echo "Error: 'git' not found in PATH." >&2
        exit 1
    fi
    if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echo "Error: not inside a git repository. Run 'git init' first." >&2
        exit 1
    fi

    local prompt_file
    prompt_file=$(resolve_prompt "$mode")

    local current_branch
    current_branch=$(git branch --show-current)

    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "Mode:   $mode"
    echo "Prompt: $prompt_file"
    echo "Branch: $current_branch"
    echo "Model:  $model"
    echo "Max:    $max_iterations iterations"
    [[ -n "$goal" ]] && echo "Goal:   $goal"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    # Permission handling:
    #   claude -p is non-interactive and cannot prompt for tool approval,
    #   so --dangerously-skip-permissions is always required.
    #   Inside a devcontainer, network isolation provides additional safety.
    if [[ "${DEVCONTAINER:-false}" != "true" ]]; then
        echo "⚠️  WARNING: Running with --dangerously-skip-permissions outside a container." >&2
        echo "⚠️  Claude will have unrestricted access to tools (file writes, shell commands, etc)." >&2
        echo "⚠️  For safer execution, use the provided devcontainer." >&2
        echo "" >&2
    fi
    local permission_flag="--dangerously-skip-permissions"

    local iteration=0

    # Clean exit on interrupt signals
    trap 'echo -e "\nInterrupted at iteration $iteration / $max_iterations" >&2; exit 130' SIGINT SIGTERM

    while [[ $iteration -lt $max_iterations ]]; do
        iteration=$((iteration + 1))
        echo -e "\n======================== ITERATION $iteration / $max_iterations ========================\n"

        # Inject {{GOAL}} into prompt using bash substitution (avoids sed escaping issues)
        local prompt
        prompt=$(<"$prompt_file")
        prompt="${prompt//\{\{GOAL\}\}/${goal:-No specific goal provided}}"

        if $dry_run; then
            echo "[dry-run] Would run: claude -p $permission_flag --output-format=stream-json --model $model --verbose"
            echo "[dry-run] Prompt content ($prompt_file with goal substituted):"
            echo "$prompt"
        else
            echo "$prompt" | claude -p \
                $permission_flag \
                --output-format=stream-json \
                --model "$model" \
                --verbose \
                | jq -r 'select(.type == "result") | .result // empty'
        fi

        # Push changes after each iteration
        if $dry_run; then
            echo "[dry-run] Would run: git push origin $current_branch"
        elif ! $skip_push; then
            local push_output
            if ! push_output=$(git push origin "$current_branch" 2>&1); then
                if echo "$push_output" | grep -q "has no upstream branch"; then
                    echo "No upstream branch found. Setting upstream..."
                    git push -u origin "$current_branch"
                else
                    echo "Push failed:" >&2
                    echo "$push_output" >&2
                    exit 1
                fi
            fi
        fi
    done

    echo -e "\nCompleted $iteration iterations."
}

# Main dispatch
case "${1:-}" in
    sandbox)    shift; cmd_sandbox "$@" ;;
    plan|build) cmd_loop "$@" ;;
    init)       shift; cmd_init "$@" ;;
    clean)      cmd_clean ;;
    archive)    cmd_archive ;;
    version)    cmd_version ;;
    -h|--help)  usage ;;
    "")         usage ;;
    *)          echo "Error: unknown command '$1'"; exit 1 ;;
esac
